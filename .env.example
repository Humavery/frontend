# Options related to the application.
# Port of the application that will run on while being run in Docker Compose.
APP_PORT=

# Options related to the website.
# Endpoint URL to the API.
NEXT_PUBLIC_API_ENDPOINT_URL=
# Endpoint URL to the CDN server to serve static files.
NEXT_PUBLIC_CDN_ENDPOINT_URL=
# Endpoint URL to the website itself, mostly for SEO and PWA configuration.
NEXT_PUBLIC_WEBSITE_ENDPOINT_URL=
